# Kopier til scripts/deploy.env og fyll inn dine verdier.
# scripts/deploy.env er gitignorert og pushes aldri.

# SSH-mål til Raspberry Pi-en (bruker@vert)
PI_HOST=pi@raspberrypi.local

# Katalogen der repoet er klonet paa Pi-en
PI_DIR=~/uv-sun-tracker

# Navn paa systemd-tjenesten (fra README)
SERVICE=sol-tracker

# Git-branch som deployes
BRANCH=main
